# Velora — Environment Variables
# Copy to .env.local and fill in values.

# Required for auth sessions (generate: openssl rand -base64 32)
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001

# MongoDB Atlas connection string
# Vercel MongoDB integration may inject velora_MONGODB_URI instead
MONGODB_URI=
MONGODB_DB=velora

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email magic link + weekly brief (https://resend.com/)
RESEND_API_KEY=
EMAIL_FROM=Velora <onboarding@yourdomain.com>

# OpenAI CFO (optional — falls back to rule engine without key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Vercel Cron security (generate random string)
CRON_SECRET=
